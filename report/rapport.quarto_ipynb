      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Appliquez votre fonction dc.impute_missing_values() avec la méthode d'interpolation\n",
        "df_final = dc.impute_missing_values(df_no_outliers, ['value'], 'interpolate')\n",
        "\n",
        "# Validation finale : vérifiez qu'il ne reste aucune valeur manquante\n",
        "print(\"Valeurs manquantes finales :\", df_final.isnull().sum())"
